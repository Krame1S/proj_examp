# ── Application ──────────────────────────────────────────
APP_NAME=my-backend
DEBUG=true
LOGGING_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# ── PostgreSQL ──────────────────────────────────────────
# asyncpg connection (used at runtime for queries)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mydb
# SQLAlchemy connection (used by Alembic for migrations)
DATABASE_URL_SQLALCHEMY=postgresql+asyncpg://postgres:postgres@localhost:5432/mydb
DB_SCHEMA=public
DB_MIN_POOL_SIZE=5
DB_MAX_POOL_SIZE=20

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Auth ────────────────────────────────────────────
# RS256 key paths (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_LIFETIME=3600
REFRESH_TOKEN_LIFETIME=604800

# ── S3 Storage ──────────────────────────────────────────
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=my-bucket
S3_PUBLIC_URL=https://my-bucket.s3.amazonaws.com
S3_REGION=us-east-1

# ── Prometheus Metrics ──────────────────────────────────
ENABLE_METRICS=true
